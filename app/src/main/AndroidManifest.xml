<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".FinTrackApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinTrackPro"
        tools:targetApi="31">

        <!-- Splash Screen -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FinTrackPro.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Auth Activity -->
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Add Transaction Activity -->
        <activity
            android:name=".ui.transactions.AddTransactionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Transaction Details Activity -->
        <activity
            android:name=".ui.transactions.TransactionDetailsActivity"
            android:exported="false" />

        <!-- Add Budget Activity -->
        <activity
            android:name=".ui.budgets.AddBudgetActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Budget Details Activity -->
        <activity
            android:name=".ui.budgets.BudgetDetailsActivity"
            android:exported="false" />

        <!-- Add Account Activity -->
        <activity
            android:name=".ui.accounts.AddAccountActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Reports Activity -->
        <activity
            android:name=".ui.reports.ReportsActivity"
            android:exported="false" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

        <!-- Shared Wallet Activity -->
        <activity
            android:name=".ui.shared.SharedWalletActivity"
            android:exported="false" />

        <!-- Achievements Activity -->
        <activity
            android:name=".ui.gamification.AchievementsActivity"
            android:exported="false" />

        <!-- File Provider for camera -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
